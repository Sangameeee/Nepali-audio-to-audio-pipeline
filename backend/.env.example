# ==============================================================================
# Vani - Environment Variables
# File: backend/.env.example
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# See backend/app/config.py for full documentation of each variable.
# ==============================================================================

# ── General ──────────────────────────────────────────────────────────────
APP_NAME=Vani
APP_VERSION=0.1.0
DEBUG=true

# Device for ML models: "cuda" (GPU) or "cpu"
DEVICE=cpu

# ── ASR Models ───────────────────────────────────────────────────────────
# English: NVIDIA NeMo Conformer checkpoint path
ASR_ENGLISH_MODEL_PATH=models/asr/english/nemo_conformer.nemo

# Nepali: ai4bharat/indic-conformer-600m-multilingual directory
ASR_NEPALI_MODEL_PATH=models/asr/nepali

# ── Remote ASR API (Colab/Kaggle + ngrok) ─────────────────────────────────
# Base URL for the Nepali ASR FastAPI server exposed via ngrok.
# Update this whenever you restart the notebook and ngrok gives a new URL.
ASR_COLAB_API_URL=
# Decoder: ctc (fast) or rnnt (more accurate, slower)
ASR_DECODER=ctc

# ── Language Detection ───────────────────────────────────────────────────
LANG_DETECT_MODEL=papluca/xlm-roberta-base-language-detection

# ── Translation Models ───────────────────────────────────────────────────
TRANSLATION_EN_TO_NE_MODEL=Helsinki-NLP/opus-mt-en-ne
TRANSLATION_NE_TO_EN_MODEL=Helsinki-NLP/opus-mt-ne-en

# ── TTS ──────────────────────────────────────────────────────────────────
TTS_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2
# Path to a reference speaker WAV for voice cloning (optional)
TTS_REFERENCE_WAV=

# ── Weather API ──────────────────────────────────────────────────────────
# Uses Open-Meteo (free, no API key required)
# Preferred country when multiple geocoding results match
WEATHER_PREFER_COUNTRY=Nepal

# ── RAG / LLM ───────────────────────────────────────────────────────────
# Path to documents for RAG system
RAG_DOCUMENTS_PATH=data/news

# ── RAG / SLM Remote API (Colab + ngrok) ─────────────────────────────────
# Base URL for the unified RAG/SLM FastAPI server exposed via ngrok.
# Must expose: POST /ask (text), POST /ask_audio (english audio)
RAG_COLAB_API_URL=

# Retrieval tuning forwarded to the remote server
RAG_MIN_COSINE=0.7
RAG_DAYS_FILTER=730
RAG_TOP_K=5

# LLM API key (Groq, OpenAI, etc.)
LLM_API_KEY=
LLM_MODEL_NAME=llama3-8b-8192

# ── Audio Processing ─────────────────────────────────────────────────────
AUDIO_SAMPLE_RATE=16000
MAX_UPLOAD_SIZE=52428800
